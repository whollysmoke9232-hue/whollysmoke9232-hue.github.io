
{# Library Landing Page - Nunjucks Template #}

<header style="text-align:center; margin-top:2.5rem; margin-bottom:1.5rem;">
  <h1 style="font-size:2.2rem; letter-spacing:0.04em; margin-bottom:0.5rem;">
    <a href="/" style="color:#6b4f2c; text-decoration:none; transition:color 0.2s;">Grace in the Margins</a>
  </h1>
  <div style="font-size:1.25rem; color:#7a6a4f; margin-bottom:1.5rem;">Library</div>
</header>

<style>
.library-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 2rem 1.5rem;
  max-width: 1400px;
  margin: 2.5rem auto 2rem auto;
  padding: 0 1.5rem;
  box-sizing: border-box;
}
.library-group {
  padding: 0 0.5rem;
}
.library-group h2 {
  text-align: center;
  font-size: 1.18rem;
  margin-bottom: 1rem;
  border-bottom: 2px solid #e0d6c3;
  padding-bottom: 0.5rem;
  position: relative;
  cursor: help;
}
.category-hover-note {
  display: none;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: calc(100% + 0.45rem);
  width: 260px;
  background: #fffbe9;
  color: #3a2a13;
  border: 1px solid #e0d6c3;
  border-radius: 6px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  padding: 0.65rem 0.85rem;
  z-index: 12;
  font-size: 0.95rem;
  line-height: 1.45;
  font-weight: normal;
}
.library-group h2:hover .category-hover-note,
.library-group h2:focus-within .category-hover-note {
  display: block;
}
.library-group--devotionals .category-hover-note {
  left: 0;
  transform: none;
  text-align: left;
}
.library-group--books .category-hover-note {
  left: auto;
  right: 0;
  transform: none;
  text-align: left;
}
.library-group--testimonies .library-excerpt,
.library-group--books .library-excerpt {
  left: auto;
  right: 105%;
  text-align: left;
}
.library-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.library-list li {
  margin-bottom: 0.7rem;
  position: relative;
}
.library-list a {
  text-decoration: underline;
  color: #6b4f2c;
  cursor: pointer;
}
.library-list a:hover + .library-excerpt,
.library-list a:focus + .library-excerpt {
  display: block;
}
.library-excerpt {
  display: none;
  position: absolute;
  left: 105%;
  top: 0;
  width: 260px;
  background: #fffbe9;
  color: #3a2a13;
  border: 1px solid #e0d6c3;
  border-radius: 6px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  padding: 0.7rem 1rem;
  z-index: 10;
  font-size: 0.98rem;
}
</style>

<div class="library-grid">
  <div class="library-group library-group--devotionals">
    <h2>Devotionals<span class="category-hover-note">Short reflections on Scripture meant to encourage faith and obedience in everyday life.</span></h2>
    <ul class="library-list">
      {% for item in collections.devotionals | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group">
    <h2>Meditations<span class="category-hover-note">Quiet contemplations on Scripture and faith, written to be read slowly and thoughtfully.</span></h2>
    <ul class="library-list">
      {% for item in collections.meditations | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group">
    <h2>Poems & Prayers<span class="category-hover-note">Psalm-like expressions of worship, longing, confession, and trust offered before God.</span></h2>
    <ul class="library-list">
      {% for item in collections.poems | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group">
    <h2>Reflections<span class="category-hover-note">Thoughtful explorations of Scripture, theology, and the deeper movements of the Christian life.</span></h2>
    <ul class="library-list">
      {% for item in collections.reflections | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group">
    <h2>Stories<span class="category-hover-note">Narratives from life that reveal deeper spiritual truths through ordinary experiences.</span></h2>
    <ul class="library-list">
      {% for item in collections.stories | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group library-group--testimonies">
    <h2>Testimonies<span class="category-hover-note">Personal accounts of God's mercy, guidance, and transforming work in a life.</span></h2>
    <ul class="library-list">
      {% for item in collections.testimonies | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group library-group--books">
    <h2>Books<span class="category-hover-note">Longer works and serialized writings exploring faith, suffering, redemption, and spiritual growth.</span></h2>
    <ul class="library-list">
      {% for item in collections.books | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

<p style="text-align:center; margin-top:2.5rem; font-size:1.05rem; color:#7a6a4f;">Hover over any article title to see a short excerpt.</p>

<div style="text-align:center; margin-top:2.5rem;">
  <a href="/" style="display:inline-block; background:#6b4f2c; color:#fffbe9; padding:0.7rem 2.2rem; border-radius:6px; font-size:1.08rem; text-decoration:none; box-shadow:0 2px 8px rgba(0,0,0,0.07); transition:background 0.2s;">Home</a>
</div>
