<!-- Guided Path Navigation Script -->
<script>
  (function() {
    const readingPaths = {{ readingPaths | dump | safe }};
    const fallbackPaths = {
      'out-of-control': [
        { url: '/library/waves/', title: 'Waves' },
        { url: '/excerpts/fractured-light/chapter-7/', title: 'Fractured Light — The Collapse' },
        { url: '/library/still-waiting/', title: 'Still Waiting' },
        { url: '/library/a-theology-of-weakness/', title: 'A Theology of Weakness' },
        { url: '/library/held-on-every-side/', title: 'Held on Every Side' },
        { url: '/library/the-big-picture/', title: 'The Big Picture' }
      ]
    };

    // Collection names for back navigation
    const collections = {
      devotionals: 'Devotionals',
      reflections: 'Reflections',
      meditations: 'Meditations',
      stories: 'Stories',
      testimonies: 'Testimonies'
    };

    // Get URL parameters
    const urlParams = new URLSearchParams(window.location.search);
    const pathName = urlParams.get('path');
    const fromCollection = urlParams.get('from');

    const normalize = (url) => {
      if (!url) return '';
      return url
        .split('#')[0]
        .split('?')[0]
        .replace(/\/+$/, '');
    };

    if (pathName) {
      const entries = readingPaths[pathName] || fallbackPaths[pathName];
      if (!entries || !entries.length) return;

      const navDiv = document.getElementById('path-navigation');
      if (!navDiv) return;

      const currentUrl = normalize(window.location.pathname);
      const index = entries.findIndex((entry) => normalize(entry.url) === currentUrl);
      if (index === -1) return;

      let pathUrl = '/' + pathName + '/';
      if (pathName.startsWith('youre-not-alone')) pathUrl = '/youre-not-alone/';
      if (pathName.startsWith('start-here')) pathUrl = '/start-here/';
      if (pathName.startsWith('hearing-god')) pathUrl = '/hearing-god/';

      let navHtml = '<nav class="explore-bubbles" aria-label="Continue Reading Path" style="display:flex;justify-content:space-between;gap:0.75rem;flex-wrap:wrap;">';

      if (index > 0) {
        const prev = entries[index - 1];
        navHtml += '<a href="' + prev.url + '?path=' + pathName + '">← ' + prev.title + '</a>';
      }

      navHtml += '<a href="' + pathUrl + '">Path Home</a>';

      if (index < entries.length - 1) {
        const next = entries[index + 1];
        navHtml += '<a href="' + next.url + '?path=' + pathName + '">' + next.title + ' →</a>';
      }

      navHtml += '</nav>';
      navDiv.innerHTML = navHtml;
      navDiv.style.display = 'block';
    }
    // Handle collection back navigation
    else if (fromCollection && collections[fromCollection]) {
      const navDiv = document.getElementById('path-navigation');
      if (!navDiv) return;

      navDiv.innerHTML = '<nav class="explore-bubbles" aria-label="Return"><a href="/' + fromCollection + '/">← Back to ' + collections[fromCollection] + '</a></nav>';
      navDiv.style.display = 'block';
    }
  })();
</script>
