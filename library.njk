
{# Library Landing Page - Nunjucks Template #}

<header style="text-align:center; margin-top:2.5rem; margin-bottom:1.5rem;">
  <h1 style="font-size:2.2rem; letter-spacing:0.04em; margin-bottom:0.5rem;">
    <a href="/" style="color:#6b4f2c; text-decoration:none; transition:color 0.2s;">Grace in the Margins</a>
  </h1>
  <div style="font-size:1.25rem; color:#7a6a4f; margin-bottom:1.5rem;">Library</div>
</header>

<section class="library-search" aria-labelledby="library-search-heading">
  <h2 id="library-search-heading">Search the Library</h2>
  <p data-library-search-status>Search by scripture, tags, themes, or article text.</p>
  <label class="library-search-label" for="library-search-input">Search</label>
  <input
    id="library-search-input"
    data-library-search-input
    type="search"
    placeholder="Try: Psalm 119, surrender, holiness, or any phrase"
    autocomplete="off"
    disabled
  />
  <p class="library-search-count" data-library-search-count></p>
  <div class="library-search-results" data-library-search-results aria-live="polite"></div>
</section>

<style>
.library-grid {
  display: grid;
  grid-template-columns: repeat(8, minmax(200px, 1fr));
  gap: 2rem 2rem;
  width: min(99vw, 3200px);
  margin: 2.5rem auto 2rem auto;
  padding: 0 0.5rem;
  box-sizing: border-box;
}
.library-group {
  padding: 0 0.5rem;
}
.library-group h2 {
  text-align: center;
  font-size: 1.18rem;
  margin-bottom: 1rem;
  border-bottom: 2px solid #e0d6c3;
  padding-bottom: 0.5rem;
  position: relative;
  cursor: help;
}
.category-hover-note {
  display: none;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  top: calc(100% + 0.45rem);
  width: 260px;
  background: #fffbe9;
  color: #3a2a13;
  border: 1px solid #e0d6c3;
  border-radius: 6px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  padding: 0.65rem 0.85rem;
  z-index: 12;
  font-size: 0.95rem;
  line-height: 1.45;
  font-weight: normal;
}
.library-group h2:hover .category-hover-note,
.library-group h2:focus-within .category-hover-note {
  display: block;
}
.library-group--devotionals .category-hover-note {
  left: 0;
  transform: none;
  text-align: left;
}
.library-group--testimonies .library-excerpt {
  left: auto;
  right: 105%;
  text-align: left;
}
.library-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.library-list li {
  margin-bottom: 0.7rem;
  position: relative;
}
.library-list a {
  text-decoration: underline;
  color: #6b4f2c;
  cursor: pointer;
}
.library-list a:hover + .library-excerpt,
.library-list a:focus + .library-excerpt {
  display: block;
}
.library-excerpt {
  display: none;
  position: absolute;
  left: 105%;
  top: 0;
  width: 260px;
  background: #fffbe9;
  color: #3a2a13;
  border: 1px solid #e0d6c3;
  border-radius: 6px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
  padding: 0.7rem 1rem;
  z-index: 10;
  font-size: 0.98rem;
}
.library-search {
  width: min(1040px, 95vw);
  margin: 0 auto 2rem auto;
  padding: 1.1rem 1.2rem;
  border: 1px solid #e0d6c3;
  border-radius: 8px;
  background: #fffdf5;
}
.library-search h2 {
  margin: 0 0 0.4rem 0;
  font-size: 1.25rem;
  color: #3a2a13;
}
.library-search p {
  margin: 0.35rem 0 0.6rem 0;
  color: #6a5738;
}
.library-search-label {
  display: block;
  margin-bottom: 0.3rem;
  font-size: 0.92rem;
  color: #5d4a2a;
}
.library-search input {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid #ccb993;
  border-radius: 6px;
  padding: 0.65rem 0.75rem;
  font-size: 1rem;
}
.library-search input:focus {
  outline: 2px solid #c29f67;
  outline-offset: 1px;
}
.library-search-count {
  font-weight: 600;
  color: #4d3a1b;
}
.library-search-results {
  display: grid;
  gap: 0.85rem;
}
.library-search-item {
  border: 1px solid #eadfc8;
  border-radius: 6px;
  background: #fffef9;
  padding: 0.7rem 0.8rem;
}
.library-search-item h3 {
  margin: 0;
  font-size: 1.05rem;
}
.library-search-item h3 a {
  color: #6b4f2c;
}
.library-search-preview {
  margin: 0.45rem 0;
  color: #4f412c;
}
.library-search-meta {
  margin: 0;
  font-size: 0.88rem;
  color: #7a6645;
}
.library-search-empty {
  margin: 0;
  color: #6a5738;
}
@media (max-width: 960px) {
  .library-grid {
    grid-template-columns: repeat(2, minmax(220px, 1fr));
    width: min(96vw, 900px);
  }
  .library-excerpt {
    display: none !important;
  }
}
@media (max-width: 560px) {
  .library-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<div class="library-grid">
  <div class="library-group library-group--books">
    <h2>Books<span class="category-hover-note">Longer works and serialized writings exploring faith, suffering, redemption, and spiritual growth.</span></h2>
    <ul class="library-list">
      {% for item in collections.books | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group library-group--devotionals">
    <h2>Devotionals<span class="category-hover-note">Short reflections on Scripture meant to encourage faith and obedience in everyday life.</span></h2>
    <ul class="library-list">
      {% for item in collections.devotionals | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group">
    <h2>Meditations<span class="category-hover-note">Quiet contemplations on Scripture and faith, written to be read slowly and thoughtfully.</span></h2>
    <ul class="library-list">
      {% for item in collections.meditations | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group">
    <h2>Poems & Prayers<span class="category-hover-note">Psalm-like expressions of worship, longing, confession, and trust offered before God.</span></h2>
    <ul class="library-list">
      {% for item in collections.poems | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group">
    <h2>Reflections<span class="category-hover-note">Thoughtful explorations of Scripture, theology, and the deeper movements of the Christian life.</span></h2>
    <ul class="library-list">
      {% for item in collections.reflections | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group">
    <h2>Stories<span class="category-hover-note">Narratives from life that reveal deeper spiritual truths through ordinary experiences.</span></h2>
    <ul class="library-list">
      {% for item in collections.stories | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
  <div class="library-group library-group--testimonies">
    <h2>Testimonies<span class="category-hover-note">Personal accounts of God's mercy, guidance, and transforming work in a life.</span></h2>
    <ul class="library-list">
      {% for item in collections.testimonies | sort(attribute='data.title') %}
        <li>
          <a href="{{ item.url }}">{{ item.data.title }}</a>
          {% if item.data.excerpt %}<span class="library-excerpt">{{ item.data.excerpt }}</span>{% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</div>

<p style="text-align:center; margin-top:2.5rem; font-size:1.05rem; color:#7a6a4f;">Hover over any article title to see a short excerpt.</p>

<div style="text-align:center; margin-top:2.5rem;">
  <a href="/" style="display:inline-block; background:#6b4f2c; color:#fffbe9; padding:0.7rem 2.2rem; border-radius:6px; font-size:1.08rem; text-decoration:none; box-shadow:0 2px 8px rgba(0,0,0,0.07); transition:background 0.2s;">Home</a>
</div>

<script src="/assets/js/search/library-search.js" defer></script>
